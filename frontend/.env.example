# Frontend Environment Variables
# Copy this file to .env and fill in the real values before running.
# Never commit the .env file.

# Backend API origin. Use your deployed backend URL in production.
VITE_API_URL=http://localhost:5000

# Supabase project URL. This is a public browser value.
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE

# Supabase anon key. This is public; Row Level Security enforces access.
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Razorpay publishable key ID. This is the public browser key only.
VITE_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
