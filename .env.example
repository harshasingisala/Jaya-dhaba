# Root Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit the .env file.

APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5000

DATABASE_URL=YOUR_SUPABASE_POSTGRES_URL_HERE
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
FLASK_SECRET_KEY=YOUR_FLASK_SECRET_KEY_HERE
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
DB_ENCRYPTION_KEY=YOUR_DB_ENCRYPTION_KEY_HERE
ENCRYPTION_KEY=YOUR_APP_ENCRYPTION_KEY_HERE
REDIS_URL=redis://localhost:6379/0
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
CLOUDFLARE_TUNNEL_SECRET=YOUR_CLOUDFLARE_ORIGIN_SECRET_HERE
REQUIRE_CLOUDFLARE_TUNNEL_SECRET=true

RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

CORS_ORIGINS=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
DOMAIN=http://localhost:5173
UPLOAD_FOLDER=backend/uploads
COOKIE_SECURE=false

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
CHATBOT_ENABLED=false
TAX_BASIS_POINTS=500
GUNICORN_BIND=unix:/run/restaurant/gunicorn.sock
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=YOUR_ADMIN_BOOTSTRAP_PASSWORD_HERE
