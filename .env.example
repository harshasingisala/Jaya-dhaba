# Root Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit the .env file.

APP_ENV=development
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5000

DATABASE_URL=YOUR_SUPABASE_POSTGRES_URL_HERE
FLASK_SECRET_KEY=YOUR_FLASK_SECRET_KEY_HERE
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
DB_ENCRYPTION_KEY=YOUR_DB_ENCRYPTION_KEY_HERE

RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

CORS_ORIGINS=http://localhost:5173
DOMAIN=http://localhost:5173
UPLOAD_FOLDER=backend/uploads
COOKIE_SECURE=false

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
CHATBOT_ENABLED=false
TAX_BASIS_POINTS=500
GUNICORN_BIND=unix:/run/restaurant/gunicorn.sock
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=YOUR_ADMIN_BOOTSTRAP_PASSWORD_HERE
